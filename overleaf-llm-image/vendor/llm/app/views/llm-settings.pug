extends ../../../../app/views/layout-react

block entrypointVar
	- entrypoint = 'modules/llm/pages/user/llm-settings'

block vars
	- isWebsiteRedesign = true

block append meta
	meta(name='ol-user' data-type='json' content=user)
	meta(name='ol-featureChatEnabled' data-type='json' content=JSON.stringify(featureFlags.chatEnabled))
	meta(name='ol-featureCompletionEnabled' data-type='json' content=JSON.stringify(featureFlags.completionEnabled))

block content
	main#main-content.content.content-alt
		#settings-page-root
