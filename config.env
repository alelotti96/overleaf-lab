# =============================================================================
# OVERLEAF-LAB UNIFIED CONFIGURATION
# =============================================================================
# This file contains all configuration for the complete Overleaf+Zotero system
#
# INSTRUCTIONS:
# 1. Copy this file to config.env.local (git-ignored)
# 2. Fill in all values below
# 3. Run ./install.sh to apply configuration and install everything
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL SETTINGS
# -----------------------------------------------------------------------------
LAB_NAME="Your Lab Name"
ADMIN_EMAIL="admin@your-domain.com"

# Enable public Zotero signup page? (true/false)
# The dashboard is always installed for admin management of Overleaf users and Zotero integration.
# This setting controls whether to expose the public /signup page via Cloudflare Tunnel:
# - Set to "true" to allow public Zotero self-registration (users can sign up via web form)
# - Set to "false" to keep signup private (admin must configure Zotero users manually via dashboard)
ENABLE_PUBLIC_ZOTERO_SIGNUP="false"

# Public URLs
# - For local testing: http://localhost
# - For production with HTTPS/reverse proxy: https://your-domain.com
OVERLEAF_URL="http://localhost"
DASHBOARD_URL="http://localhost:5000"

# Behind reverse proxy with HTTPS? (true/false)
# - Set to "false" for local testing (http://localhost)
# - Set to "true" for production with HTTPS and reverse proxy
BEHIND_PROXY="false"

# Use secure cookies? (true/false)
# IMPORTANT: Must be "false" if using HTTP (without HTTPS)
# - Set to "false" for local testing (http://localhost)
# - Set to "true" for production with HTTPS
USE_SECURE_COOKIES="false"

# -----------------------------------------------------------------------------
# OVERLEAF CONFIGURATION
# -----------------------------------------------------------------------------
# Compile timeout in seconds (default: 180 = 3 minutes)
COMPILE_TIMEOUT="180"

# Enable sandboxed compiles (isolates each compile in a separate container for security)
SANDBOXED_COMPILES="true"

# Enable track changes (true/false)
TRACK_CHANGES_ENABLED="true"

# Overleaf port (default: 80, or 300 for custom)
OVERLEAF_PORT="80"

# Password validation (passfield format)
# Pattern: a=lowercase, A=uppercase, 1=number, $=symbol
# Example: "a1$" requires 1 letter, 1 number, 1 symbol
PASSWORD_VALIDATION_PATTERN="a1$"
PASSWORD_VALIDATION_MIN_LENGTH="8"

# Super Admin email (this user gets super_admin role automatically at container startup)
# Super Admins can access "Manage Site" (/admin) and "Manage Projects" (/admin/project)
# Normal admins can only access "Manage Users" (/admin/user)
# Additional super_admins can be set via the dashboard
SUPER_ADMIN_EMAIL=""

# Invite token secret (required by Overleaf CE >= 6.2.0, the container refuses
# to start without it). Auto-generated at install time if left empty.
OVERLEAF_INVITE_TOKEN_SECRET=""

# Overleaf public registration page (/register, native since CEP ext-v5.0)
# WARNING: if the underlying env var is NOT set, CEP auto-enables the page
# whenever no external auth (OIDC/LDAP/SAML) is configured - anyone reaching
# your Overleaf URL could create an account. Keep "false" for private labs.
ENABLE_OVERLEAF_PUBLIC_REGISTRATION="false"

# -----------------------------------------------------------------------------
# DOCUMENT CONVERSION (Pandoc)
# -----------------------------------------------------------------------------
# Import Microsoft Word / Markdown documents and export projects as
# docx / Markdown / HTML. Experimental upstream feature, enabled by default.
ENABLE_PANDOC_CONVERSIONS="true"

# Conversion image, pulled at install/update time. Must include zip and have an
# empty entrypoint - the official pandoc Docker image does NOT work.
PANDOC_IMAGE="overleafcep/pandoc-ol:3.10.0.0"

# -----------------------------------------------------------------------------
# AI ASSISTANT (LLM)
# -----------------------------------------------------------------------------
# Optional in-editor AI assistant (chat + inline completion) backed by an
# OpenAI-compatible LLM endpoint (local llama.cpp / llama-server, vLLM, Ollama
# with its OpenAI shim, or any hosted OpenAI-compatible API).
#
# OPT-IN and REVERSIBLE: while ENABLE_LLM_MODULE="false" (the default) NOTHING
# changes - the stock Overleaf image is used and no LLM env vars are written, so
# behavior is byte-for-byte identical to a build without this feature. Setting it
# "true" swaps OVERLEAF_IMAGE to a locally-built custom image
# (overleaf-lab/sharelatex-llm) that you must build first - see
# overleaf-llm-image/README (build with ./scripts/build-llm-image.sh).
ENABLE_LLM_MODULE="false"    # opt-in; true requires building overleaf-llm-image (see its README)

# OpenAI-compatible endpoint; must include the /v1 segment
LLM_API_URL="http://YOUR-LLAMA-SERVER:8080/v1"

# Bearer token; leave empty for a local llama.cpp server with no auth
LLM_API_KEY=""

# Comma-separated; first = default. Leave empty to auto-discover via /models
LLM_MODEL_NAME=""

# Optional: override the model used for inline completion (defaults to the chat model)
LLM_COMPLETION_MODEL=""

# true = each user can set their OWN endpoint+key (bring-your-own OpenAI / Claude / any
# OpenAI-compatible API) in their "AI Settings"; a "Personal" model then appears in the chat
# picker and routes to THEIR key. Coexists with the shared LLM_API_URL above.
# NOTE: user keys are encrypted at rest in Mongo via LLM_KEY_SECRET (see below).
LLM_ALLOW_USER_SETTINGS="true"

# LLM_KEY_SECRET (do NOT set here): when ENABLE_LLM_MODULE="true", configure.sh
# auto-generates this secret ONCE and persists it to config.env.local, then
# reuses it on every run. It derives the AES-256-GCM key that encrypts each
# user's personal API key (User.llmApiKey) at rest in Mongo. CHANGING or LOSING
# it makes all previously stored user keys undecryptable, forcing every user to
# re-enter their key. It is intentionally left out of this template so it is
# never committed - let configure.sh manage it.

# -----------------------------------------------------------------------------
# BRANDING: FOOTER & HEADER
# -----------------------------------------------------------------------------
# Footer "Fork on GitHub" link (bottom-right of the page). Point it to your fork.
FOOTER_FORK_TEXT="Fork on GitHub!"
FOOTER_FORK_URL="https://github.com/alelotti96/overleaf-lab/tree/master"

# Footer credit (bottom-left, next to the copyright). Leave text empty to omit.
FOOTER_CREDIT_TEXT="Maintained by Alessandro Lotti"
FOOTER_CREDIT_URL="https://alessandrolotti.com/"

# Hide the "© 2025 Powered by Overleaf" line (true/false)
HIDE_POWERED_BY="false"

# Dashboard header (navbar) color. Overleaf 6.2 ships a WHITE header; set a
# background color here to restore a dark header (old-CE look). The color is
# injected as CSS via nginx (scripts/nginx-customizations.sh).
# Leave HEADER_BG_COLOR empty ("") to keep the default white header.
HEADER_BG_COLOR="#1b222c"
HEADER_TEXT_COLOR="#ffffff"

# Maximum upload size in MB (default: 500)
# Applied to both nginx (client_max_body_size) and the web app (maxUploadSize)
MAX_UPLOAD_SIZE_MB="500"

# Enabled linked file types
ENABLED_LINKED_FILE_TYPES="project_file,project_output_file,url"

# Dashboard signup URL (for Zotero integration link)
# Change this to your actual signup page URL
DASHBOARD_SIGNUP_URL="http://localhost:5000/zotero/signup"

# Signup subdomain for auto-redirect (set by cloudflare tunnel script)
# When visitors access this subdomain, they're redirected to /zotero/signup
SIGNUP_SUBDOMAIN=""

# -----------------------------------------------------------------------------
# OIDC AUTHENTICATION (Single Sign-On)
# -----------------------------------------------------------------------------
# Enable login via Microsoft/Google with automatic account creation
# Requires app registration in Azure/Google (see documentation)
ENABLE_OIDC="false"

# OIDC Provider Configuration (only needed if ENABLE_OIDC="true")
OIDC_PROVIDER_NAME="SSO Provider"
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_ISSUER=""  # Auto-set during install based on provider type
OIDC_AUTHORIZATION_URL=""  # Auto-set during install
OIDC_TOKEN_URL=""  # Auto-set during install
OIDC_USER_INFO_URL=""  # Auto-set during install
OIDC_END_SESSION_URL=""  # Auto-set during install (for logout)
OIDC_SCOPE="openid profile email"
OIDC_ALLOWED_DOMAINS=""  # Comma-separated (e.g., "company.com,university.edu")

# Azure Multi-Tenant Support (optional)
# If your organization has multiple Azure tenants, list their IDs here (comma-separated)
# Example: "tenant-id-1,tenant-id-2"
OIDC_ADDITIONAL_TENANT_IDS=""

# Group-Based Access Control (optional)
# Restrict access to specific Azure AD groups
# Set to "true" to enable, "false" to allow all authenticated users
OIDC_GROUP_FILTERING_ENABLED="false"
# Comma-separated list of Azure AD group Object IDs
# Find group IDs in Azure Portal > Azure Active Directory > Groups > [Group] > Object ID
# Example: "abc12345-1234-1234-1234-123456789abc,def67890-5678-5678-5678-567890123def"
OIDC_ALLOWED_GROUPS=""

# Docker image to use
# - Default: overleafcep/sharelatex (Extended CE with premium features)
# - After LaTeX install: local/sharelatex-texlive-full
OVERLEAF_IMAGE="overleafcep/sharelatex"
OVERLEAF_IMAGE_TAG="6.2.0-ext-v5.0"

# MongoDB version (8.0 required by Overleaf 6.x, needs CPU with AVX support)
MONGO_VERSION="8.0"

# Data paths (relative to overleaf-toolkit/ directory)
OVERLEAF_DATA_PATH="./data/overleaf"
MONGO_DATA_PATH="./data/mongo"
REDIS_DATA_PATH="./data/redis"


# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (SMTP)
# -----------------------------------------------------------------------------
EMAIL_FROM_ADDRESS="noreply@your-domain.com"

# SMTP Settings
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_TLS_REJECT_UNAUTH="true"
SMTP_IGNORE_TLS="false"

# Disable email confirmation requirement (true/false)
EMAIL_CONFIRMATION_DISABLED="true"

# -----------------------------------------------------------------------------
# DASHBOARD (overleaf-zotero-manager) CONFIGURATION
# -----------------------------------------------------------------------------
# Flask secret key (GENERATE with: python3 -c 'import secrets; print(secrets.token_hex(32))')
FLASK_SECRET_KEY=""

# Dashboard admin credentials
DASHBOARD_ADMIN_PASSWORD=""  # CHANGE THIS!

# Flask settings
FLASK_DEBUG="False"
FLASK_PORT="5000"

# MongoDB connection (leave as-is for docker setup)
MONGODB_URI="mongodb://mongo:27017/sharelatex?directConnection=true"

# Zotero proxy Docker image name
ZOTERO_PROXY_IMAGE="zotero-overleaf-proxy:local"

# Session security (for Dashboard)
# IMPORTANT: SESSION_COOKIE_SECURE must be "False" if using HTTP (without HTTPS)
# - Set to "False" for local testing (http://localhost)
# - Set to "True" for production with HTTPS
SESSION_COOKIE_SECURE="False"
SESSION_COOKIE_HTTPONLY="True"
SESSION_COOKIE_SAMESITE="Lax"

# Logging
LOG_LEVEL="INFO"
LOG_FILE="logs/app.log"

# NOTE: Individual Zotero users will be added via the dashboard web UI
